[
  {
     "topicName": "Transmission Modes",
    "front": "What is data transmission?",
    "back": "The process of sending data from one device to another."
  },
  {
     "topicName": "Transmission Modes",
    "front": "What is serial transmission?",
    "back": "Data is sent one bit at a time over a single wire."
  },
  {
     "topicName": "Transmission Modes",
    "front": "What is parallel transmission?",
    "back": "Multiple bits are sent at the same time over multiple wires."
  },
  {
     "topicName": "Transmission Modes",
    "front": "Give one advantage of parallel transmission",
    "back": "Faster over short distances."
  },
  {
     "topicName": "Transmission Modes",
    "front": "Give one disadvantage of parallel transmission",
    "back": "Crosstalk or skew."
  },
  {
     "topicName": "Transmission Modes",
    "front": "Give one advantage of serial transmission",
    "back": "Reliable over long distances."
  },
  {
     "topicName": "Transmission Modes",
    "front": "What is simplex transmission?",
    "back": "Data flows in one direction only."
  },
  {
     "topicName": "Transmission Modes",
    "front": "What is half-duplex transmission?",
    "back": "Data flows both ways but not at the same time."
  },
  {
     "topicName": "Transmission Modes",
    "front": "What is full-duplex transmission?",
    "back": "Data flows both ways at the same time."
  },
  {
     "topicName": "Transmission Modes",
    "front": "What is USB?",
    "back": "A standard interface that uses serial transmission to connect devices."
  },

  {
     "topicName": "Transmission Modes",
    "front": "What does USB stand for?",
    "back": "Universal Serial Bus."
  },
  {
     "topicName": "Transmission Modes",
    "front": "What is USB used for?",
    "back": "Connecting devices and transmitting data using serial transmission."
  },
  {
     "topicName": "Transmission Modes",
    "front": "Give one advantage of USB",
    "back": "Provides power and data through one cable."
  },
  {
     "topicName": "Transmission Modes",
    "front": "Give another advantage of USB",
    "back": "Plug and play (automatically recognised)."
  },
  {
     "topicName": "Transmission Modes",
    "front": "What does hot-swappable mean?",
    "back": "Devices can be connected or removed without restarting the computer."
  },
  {
     "topicName": "Transmission Modes",
    "front": "Give another advantage of USB",
    "back": "Supports many different devices."
  },
  {
     "topicName": "Transmission Modes",
    "front": "Give one disadvantage of USB",
    "back": "Limited cable length."
  },
  {
     "topicName": "Transmission Modes",
    "front": "Give another disadvantage of USB",
    "back": "Can be slower than some other connection types."
  }
]
